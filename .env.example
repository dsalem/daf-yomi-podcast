# Internet Archive S3-compatible API credentials.
# Get these from https://archive.org/account/s3.php after creating an IA account.
# These are also picked up automatically by `ia configure`.
IA_ACCESS_KEY=
IA_SECRET_KEY=

# Public base URL where feed.xml will be hosted (no trailing slash).
# e.g. https://yourname.github.io/daf-yomi-podcast
FEED_BASE_URL=https://example.com/daf-yomi-podcast

# Public URL for the podcast cover art (1400x1400 to 3000x3000 JPEG/PNG).
# Apple/Spotify require this. Host on Internet Archive or GitHub raw.
COVER_ART_URL=https://example.com/cover.jpg

# IA collection. opensource_audio is the free public default.
IA_COLLECTION=opensource_audio

# Path to the SQLite DB (default: ./dafyomi.db).
DAFYOMI_DB=sqlite:///./dafyomi.db
